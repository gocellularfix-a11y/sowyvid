{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "jsx": "react-jsx",
    "types": ["node", "vite/client"],
    "outDir": "./out/types-web",
    "noEmit": true
  },
  "include": [
    "src/app/**/*.ts",
    "src/app/**/*.tsx",
    "src/features/**/*.ts",
    "src/features/**/*.tsx",
    "src/shared/**/*.ts",
    "src/config/**/*.ts",
    "packages/northstar-creative-engine/src/**/*.ts",
    "packages/framelogic-visual-engine/src/**/*.ts",
    "src/render/compositions/**/*.tsx"
  ],
  "exclude": ["src/features/**/*.node.ts", "**/*.test.ts", "**/*.spec.ts"]
}
