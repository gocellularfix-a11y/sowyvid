{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "composite": true,
    "lib": ["ES2022"],
    "types": ["node"],
    "outDir": "./out/types-node",
    "noEmit": true
  },
  "include": [
    "src/electron/**/*.ts",
    "src/database/**/*.ts",
    "src/render/**/*.ts",
    "src/shared/**/*.ts",
    "src/config/**/*.ts",
    "packages/northstar-creative-engine/src/**/*.ts",
    "src/features/**/*.ts",
    "src/features/**/*.node.ts",
    "electron.vite.config.ts",
    "scripts/**/*.mjs"
  ]
}
