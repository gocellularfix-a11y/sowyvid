{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "noImplicitReturns": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": false,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "verbatimModuleSyntax": false,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["src/shared/*"],
      "@app/*": ["src/app/*"],
      "@electron/*": ["src/electron/*"],
      "@features/*": ["src/features/*"],
      "@database/*": ["src/database/*"],
      "@render/*": ["src/render/*"],
      "@config/*": ["src/config/*"],
      "@jorge-engines/northstar-creative": ["packages/northstar-creative-engine/src/index.ts"],
      "@jorge-engines/northstar-creative/remotion": [
        "packages/northstar-creative-engine/src/adapters/remotion.ts"
      ],
      "@jorge-engines/mediavault": ["packages/mediavault-engine/src/index.ts"],
      "@jorge-engines/framelogic-visual": ["packages/framelogic-visual-engine/src/index.ts"],
      "@jorge-engines/soundweave-audio": ["packages/soundweave-audio-engine/src/index.ts"]
    }
  }
}
