# Dependencies
node_modules/
.pnp
.pnp.js

# Build output
out/
dist/
release/
*.tsbuildinfo

# Electron / packaging
app-builds/
.electron-builder-cache/

# Test artifacts
coverage/
playwright-report/
test-results/
