# Local user data must NEVER be committed
# (SowyVid stores user projects/media in the OS app-data dir, not here.)
/userdata-dev/
*.mp4
*.mov
*.webm
!docs/**/*.mp4

# Secrets & local config
.env
.env.*
!.env.example
*.pem
*.key
secrets.json

# Logs
logs/
*.log
npm-debug.log*

# Harness / tooling session state (not project work)
.omc/
.claude/settings.local.json

# Editor / OS
.DS_Store
Thumbs.db
.idea/
.vscode/*
!.vscode/extensions.json

# Remotion / render temp
.remotion/
render-temp/

# sql.js wasm is a dependency artifact, keep it out of git if copied
public/sql-wasm.wasm
