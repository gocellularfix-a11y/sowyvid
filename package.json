{
  "name": "sowyvid",
  "version": "0.1.0",
  "description": "SowyVid — a visual, intelligent commercial-creation desktop app for ordinary business owners.",
  "author": "SowyVid",
  "license": "UNLICENSED",
  "private": true,
  "main": "./out/main/index.js",
  "//main": "electron-vite emits out/main/index.js (ESM) and out/preload/index.cjs",
  "type": "module",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "electron-vite dev",
    "dev:renderer-only": "vite --config vite.renderer.config.ts",
    "start": "electron-vite preview",
    "build": "electron-vite build",
    "build:win": "electron-vite build && electron-builder --win",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:electron": "npm run build && playwright test --config playwright.electron.config.ts",
    "postinstall": "node scripts/copy-sql-wasm.mjs",
    "verify:render": "vitest run src/features/render/realRender.test.ts --testTimeout=900000"
  },
  "dependencies": {
    "@remotion/renderer": "^4.0.230",
    "ffmpeg-static": "^5.3.0",
    "ffprobe-static": "^3.1.0",
    "nanoid": "^5.0.9",
    "qrcode": "^1.5.4",
    "sql.js": "^1.12.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.49.1",
    "@remotion/bundler": "^4.0.230",
    "@remotion/player": "^4.0.230",
    "@types/node": "^22.10.2",
    "@types/qrcode": "^1.5.5",
    "@types/react": "^18.3.17",
    "@types/react-dom": "^18.3.5",
    "@types/sql.js": "^1.4.9",
    "@vitejs/plugin-react": "^4.3.4",
    "electron": "^33.3.0",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "playwright": "^1.49.1",
    "prettier": "^3.4.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "remotion": "^4.0.230",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
